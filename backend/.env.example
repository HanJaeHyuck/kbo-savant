# ===== 백엔드 환경변수 (Railway에 설정) =====
# DB — Railway PostgreSQL 플러그인이 DATABASE_URL 자동 주입
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/railway

# 보안 (32자 이상)
SECRET_KEY=change-me-to-a-secure-32char-minimum-secret

# 크롤러
CRAWL_DELAY=1.5
KBO_BASE_URL=https://www.koreabaseball.com
STATIZ_BASE_URL=https://www.statiz.co.kr

# 스케줄러
CRAWL_HOUR=1
CRAWL_MINUTE=0
TIMEZONE=Asia/Seoul

# 환경 — 프로덕션 프론트 도메인을 CORS 허용 목록에 추가
ENVIRONMENT=production
ALLOWED_ORIGINS=https://kbo-savant.vercel.app

# ML 모델 표본 최소 기준
MIN_SAMPLE_PA=50
MIN_SAMPLE_IP=20
